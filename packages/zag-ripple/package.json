{
  "name": "zag-ripple",
  "version": "0.1.4",
  "description": "RippleJS Adapter for Zag JS",
  "keywords": [
    "js",
    "machine",
    "xstate",
    "statechart",
    "component",
    "zag-js",
    "RippleJS",
    "ripple"
  ],
  "author": "Abraham Aremu <anubra266@gmail.com>",
  "homepage": "https://github.com/anubra266/zag-ripple#readme",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/anubra266/zag-ripple/tree/main/packages/zag-ripple",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/anubra266/zag-ripple/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun run build && vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "clean-package": "./clean-package.config.json",
  "dependencies": {
    "@zag-js/core": "^1.41.1",
    "@zag-js/types": "^1.41.1",
    "@zag-js/utils": "^1.41.1"
  },
  "peerDependencies": {
    "ripple": ">=0.3.0"
  },
  "devDependencies": {
    "@ripple-ts/vite-plugin": "^0.3.72",
    "clean-package": "2.2.0",
    "jsdom": "^28.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
